# --- Rust / Cargo Artifacts ---
# Contains compiled binaries, libraries, and build artifacts
/target/

# Generated by Cargo during local builds
Cargo.lock

# Backup files generated by Cargo commands
**/*.rs.bk

# --- Emacs Temporary Files ---
# Auto-save files (e.g., #main.rs#)
\#*\#

# Lock files / Symlinks created during active editing (e.g., .#main.rs)
.\#*

# Backup files created on save (e.g., main.rs~)
*~

# Directory-local variables configuration (if you want to keep them private)
# .dir-locals.cellar.el
.dir-locals.el

# --- Optional: IDE / LSP Plugins (if using rustic or eglot) ---
.eglot/
.rust-analyzer/
.cache/
.claude/